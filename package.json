{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm run lint && pnpm run mdx:timestamps && next build",
    "start": "next start",
    "postbuild": "next-sitemap",
    "mdx:timestamps": "node ./scripts/update-mdx-timestamps",
    "lint:style": "pnpm exec stylelint \"app/**/*.css\" \"components/**/*.css\" \"styles/**/*.css\" --fix",
    "lint:biome": "pnpm exec biome check --fix --unsafe app components lib public scripts styles types *.json *.mjs *.ts *.tsx",
    "lint:prettier": "pnpm exec prettier app components lib public scripts styles types *.json *.mjs *.ts *.tsx --write --log-level warn",
    "lint": "pnpm run lint:style && pnpm run lint:prettier && pnpm run lint:biome"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@rehype-pretty/transformers": "^0.13.2",
    "@types/mdx": "^2.0.13",
    "@vercel/edge": "^1.3.1",
    "@vercel/functions": "^3.5.1",
    "clsx": "^2.1.1",
    "create-stylelint": "^1.0.1",
    "framer-motion": "^12.38.0",
    "fs": "^0.0.2",
    "gray-matter": "^4.0.3",
    "highlight.js": "^10",
    "lucide": "^1.14.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "next-view-transitions": "^0.3.5",
    "path": "^0.12.7",
    "postcss-nested": "^7.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reading-time-estimator": "^2.6.0",
    "rehype-highlight": "^7.0.2",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "remark-toc": "^9.0.0",
    "shiki": "^4.0.2",
    "tailwind-highlightjs": "^2.0.1",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.14",
    "prettier": "3.8.3",
    "stylelint": "^17.11.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
